# Cloudflare Workers のエンドポイント URL
# ローカル開発時: http://localhost:8787
# Worker dev 環境: https://<your-worker>-development.workers.dev
# 本番: https://<your-worker>-production.workers.dev
EXPO_PUBLIC_API_URL=http://localhost:8787

# データ配信ホスト（GitHub raw or Cloudflare R2 等）
# 未設定ならリモートからのデータ更新は無効化される（バンドル版のみ使用）
# 設定例:
#   EXPO_PUBLIC_DATA_HOST=https://raw.githubusercontent.com/hohoemi-rabo/suteru/main/data
# データ配信ファイル構成（host 配下）:
#   common/meta.json, common/items.json, common/patterns.json,
#   common/categories.json, common/basic-rules.json, common/special-disposal.json,
#   common/facilities.json, common/recycle-stations.json, areas/areas.json
# EXPO_PUBLIC_DATA_HOST=
